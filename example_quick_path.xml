<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="example quick path" parallel="false">
    <listeners>
        <listener class-name="configs.listeners.Listener"/>
        <listener class-name="configs.listeners.TimeoutExceptionListener"/>
    </listeners>

    <test name="Setup Main Flow English Tests">
        <parameter name="language" value="english"/>
        <parameter name="browser" value="chrome"/>
        <parameter name="branch" value="production"/>
        <classes>
            <class name="base.Setup">
                <methods>
                    <exclude name="setUpRemoteDriver"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="WE WILL Public Home English Example">
        <classes>
            <class name="tests.examples.wewill.home.WeWillHomePageTest"/>
        </classes>
    </test>

    <test name="Tear Down Test">
        <classes>
            <class name="base.TearDownTest"/>
        </classes>
    </test>
</suite>
