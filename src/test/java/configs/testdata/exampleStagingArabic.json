{
  "base-url": {
    "env": {
      "english": "https://wewill.tech/",
      "arabic": "https://wewill.tech/"
    }
  },
  "api": {
    "baseUrl": "https://jsonplaceholder.typicode.com",
    "contractValidation": {
      "enabled": true,
      "specificationPath": "src/test/resources/openapi/jsonplaceholder-posts-v1.json"
    },
    "posts": {
      "getOne": {
        "description": "Get example public post",
        "endpoint": "/posts/1",
        "expectedStatus": 200,
        "expectedContentType": "application/json",
        "expectedId": 1,
        "expectedTitle": "sunt aut facere repellat provident occaecati excepturi optio reprehenderit"
      },
      "createOne": {
        "description": "Create example public post",
        "endpoint": "/posts",
        "requestBody": {
          "title": "willenium sample post",
          "body": "sample api contract body",
          "userId": 77
        },
        "expectedStatus": 201,
        "expectedContentType": "application/json",
        "expectedTitle": "willenium sample post",
        "expectedUserId": 77
      }
    }
  },
  "wewillHome": {
    "heroHeading": "نحن لا نختبر البرمجيات فحسب.",
    "primaryCta": "احجز جلسة وضوح",
    "methodologyHeading": "جودة ميزات GenAI وحوكمة القرار",
    "bilingualOfferingCta": "استكشف (EN/AR)",
    "footerSlogan": "قلل الوقت، قلل التكلفة، وكن واثقاً"
  }
}
