<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Open Assistant Home Page">
    <listeners>
        <listener class-name="configs.listeners.Listener"/>
        <listener class-name="configs.listeners.TimeoutExceptionListener"/>
    </listeners>
    <parameter name="userType" value="validUser"></parameter>
    <test name="Home page opened successfully">
        <classes>
            <class name="tests.assistant.sidebar.AssistantSidebarTest"/>
            <class name="tests.assistant.home.AssistantHomePageTest"/>
            <class name="tests.assistant.home.TopicCardTest"/>
        </classes>
    </test>
</suite>