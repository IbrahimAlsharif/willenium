<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="short xml path" parallel="false">
    <listeners>
        <listener class-name="configs.listeners.Listener"/>
        <listener class-name="configs.listeners.TimeoutExceptionListener"/>
    </listeners>

    <test name="Setup Main Flow Tests">
        <parameter name="language" value="english"/>
        <parameter name="browser" value="firefox"/>
        <parameter name="branch" value="production"/>
        <classes>
            <class name="base.Setup">
                <methods>
                    <exclude name="setUpRemoteDriver"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="User Sign in with google successfully">
        <classes>
            <class name="tests.assistant.login.LoginTest"/>
        </classes>
    </test>

    <test name="Tear Down Test">
        <classes>
            <class name="base.TearDownTest"/>
        </classes>
    </test>
</suite>